# ─────────────────────────────────────────────────────────────────────────────
# EHS MCP Server — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Azure AD / SharePoint OAuth2 (client credentials flow)
SHAREPOINT_TENANT_ID=your-tenant-id-here
SHAREPOINT_CLIENT_ID=your-app-registration-client-id
SHAREPOINT_CLIENT_SECRET=your-app-registration-client-secret

# SharePoint site info (used by listSharePointFiles)
# Find via: GET https://graph.microsoft.com/v1.0/sites/{hostname}:/sites/{site-name}
SHAREPOINT_SITE_URL=https://contoso.sharepoint.com/sites/EHS
SHAREPOINT_SITE_ID=contoso.sharepoint.com,xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx,yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy
SHAREPOINT_DRIVE_ID=b!xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
